# Copy this file to .env.local (for local dev) or .env.production (for Hostinger)
# Never commit .env.local or .env.production to git

# Database
DB_HOST=localhost
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password

# Site URLs
SITE_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Admin credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASS=change_this_password

# SMTP — contact form email delivery (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=support@codimai.com
SMTP_PASS=your_hostinger_email_password
CONTACT_TO=support@codimai.com

# Environment (true = show errors, false = hide errors)
DEBUG=false
